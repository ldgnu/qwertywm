* {
    font-family: "Terminus";
    font-weight: bold;
    font-size: 14px;
    min-height: 0;
    padding: 0;
    margin: 0;
}
window#waybar {
    background: $BG;
    color: $FG;
    border: none;
}
#custom-qwertywm { color: $FG; background: $BG; padding: 0 12px; }
#custom-conn { color: $MAGENTA; background: $BG; padding: 0 12px; }
#custom-weather { color: $YELLOW; background: $BG; padding: 0 12px; }
#custom-tailscale { color: $BLUE; background: $BG; padding: 0 12px; }
#custom-cpu { color: $GREEN; background: $BG; padding: 0 12px; }
#custom-gpu { color: $CYAN; background: $BG; padding: 0 12px; }
#custom-date { color: $GREEN; background: $BG; padding: 0 12px; }
#clock { color: $CYAN; background: $BG; padding: 0 12px; }
